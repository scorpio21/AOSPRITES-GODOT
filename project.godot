; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="AOSprites"
config/description="Procesador de Cuerpos para Argentum Online"
config/version="1.0"
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://assets/logo.png"
config/edition="PRO"

[autoload]

AOLogger="*res://scripts/AOLogger.gd"
SpriteData="*res://scripts/SpriteData.gd"

[debug]

gdscript/warnings/integer_division=0

[display]

window/size/viewport_width=1400
window/size/viewport_height=900
window/size/min_width=1100
window/size/min_height=700
window/drop_files/enabled=true
display/window/subwindows/embed_subwindows=false

[logging]

file_logging/enable_file_logging=true
file_logging/log_path="res://log/godot.log"
file_logging/max_log_files=5

[rendering]

textures/canvas_textures/default_texture_filter=0
